{
	"name": "@andylovescode/binspec",
	"exports": {
		".": "./src/mod.ts",
		"./cli": "./src/cli.ts"
	},
	"license": "WTFPL",
	"version": "0.4.0",
	"tasks": {
		"dev": "deno run --watch --allow-all ./src/cli.ts ./example/spec.ts ./example/spec.gen.ts & deno fmt --watch",
		"fl": "deno lint --fix && deno fmt"
	},
	"fmt": {
		"useTabs": true,
		"semiColons": false
	},
	"lint": {
		"rules": {
			"include": ["eqeqeq", "camelcase"]
		}
	},
	"compilerOptions": {
		"isolatedDeclarations": true
	},
	"imports": {
		"@cliffy/command": "jsr:@cliffy/command@^1.0.0",
		"@std/assert": "jsr:@std/assert@^1.0.19",
		"@std/path": "jsr:@std/path@^1.1.4"
	},
	"publish": {
		"include": [
			"./src/*",
			"README.md",
			"LICENSE"
		]
	}
}
