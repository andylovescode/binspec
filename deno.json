{
	"tasks": {
		"dev": "deno run --watch --allow-all ./src/mod.ts ./example/spec.ts ./example/spec.gen.ts",
		"fl": "deno lint --fix && deno fmt",
		"devfmt": "deno fmt --watch"
	},
	"fmt": {
		"useTabs": true,
		"semiColons": false
	},
	"lint": {
		"rules": {
			"include": ["eqeqeq", "camelcase"]
		}
	},
	"compilerOptions": {
		"isolatedDeclarations": true
	},
	"imports": {
		"@cliffy/command": "jsr:@cliffy/command@^1.0.0",
		"@std/assert": "jsr:@std/assert@^1.0.19",
		"@std/path": "jsr:@std/path@^1.1.4"
	}
}
